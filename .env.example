# Resume Analyzer backend environment

# Option A: Supabase pooler (recommended for hosted apps)
# Replace with your real string from Supabase -> Project Settings -> Database -> Connection string
DATABASE_URL=postgresql+psycopg2://postgres.[YOUR-PROJECT-REF]:YOUR_DB_PASSWORD@[YOUR-POOLER-HOST]:6543/postgres?sslmode=require

# Option B: Local PostgreSQL
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/resume_analyzer

# Allowed frontend origins (comma separated). Use * only for development.
CORS_ORIGINS=*

# Max upload size in MB
MAX_UPLOAD_MB=10

# Backend port
PORT=8080
